{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .customizer-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .customizer-layout {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  @media screen and (min-width: 750px) {
    .customizer-layout {
      grid-template-columns: 1fr 1fr;
    }
  }

  .board-preview {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .board-preview-image {
    border-radius: 12px;
    overflow: hidden;
    background-color: #f5f5f5;
    aspect-ratio: 1;
  }

  .board-preview-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .board-preview-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
    color: rgb(var(--color-foreground));
  }

  .customizer-form-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    font-weight: 600;
    font-size: 1rem;
    color: rgb(var(--color-foreground));
  }

  .form-input,
  .form-textarea,
  .form-file {
    padding: 0.75rem 1rem;
    border: 2px solid #FF1493;
    border-radius: 8px;
    font-size: 1rem;
    font-family: inherit;
    background-color: white;
    color: rgb(var(--color-foreground));
    transition: all 0.3s ease;
  }

  .form-input:focus,
  .form-textarea:focus,
  .form-file:focus {
    outline: none;
    box-shadow: 0 0 0 3px rgba(255, 20, 147, 0.1);
    border-color: #FF69B4;
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-file::file-selector-button {
    padding: 0.5rem 1rem;
    background-color: #FF1493;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .form-file::file-selector-button:hover {
    background-color: #FF69B4;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-submit-btn {
    padding: 1rem 2rem;
    background-color: #FF1493;
    color: white;
    border: 2px solid #FF1493;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 1rem;
  }

  .form-submit-btn:hover {
    background-color: #FF69B4;
    border-color: #FF69B4;
    box-shadow: 0 8px 32px rgba(255, 20, 147, 0.5);
    transform: translateY(-2px);
  }

  .form-submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .success-message {
    display: none;
    padding: 1.5rem;
    background-color: #f0f0f0;
    border-radius: 8px;
    border-left: 4px solid #FF1493;
    margin-top: 1rem;
  }

  .success-message.show {
    display: block;
  }

  .success-message h3 {
    margin: 0 0 0.5rem 0;
    color: rgb(var(--color-foreground));
  }

  .success-message p {
    margin: 0;
    color: rgba(var(--color-foreground), 0.75);
  }

  .error-message {
    display: none;
    padding: 1rem;
    background-color: #fee;
    border-radius: 8px;
    border-left: 4px solid #f44;
    color: #c00;
    margin-bottom: 1rem;
  }

  .error-message.show {
    display: block;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient">
  <div class="customizer-section section-{{ section.id }}-padding">
    <div class="page-width">
      <h1 style="text-align: center; margin-bottom: 2rem;">Design Your Board</h1>

      <div class="customizer-container">
        <div class="customizer-layout">
          <!-- Board Preview -->
          <div class="board-preview">
            <div class="board-preview-image" id="board-preview-image">
              <!-- Image will be loaded by JavaScript -->
            </div>
            <h2 class="board-preview-title" id="board-preview-title">Select a board</h2>
            <p id="board-not-found" style="text-align: center; color: #999;">Loading board details...</p>
          </div>

          <!-- Form -->
          <div class="customizer-form-section">
            <div id="error-message" class="error-message"></div>

            <form id="board-customizer-form" class="customizer-form">
              <input type="hidden" id="board-handle" name="board_handle">

              <div class="form-group">
                <label for="design-file" class="form-label">Upload Your Design *</label>
                <input type="file" id="design-file" name="design_file" class="form-file" accept=".jpg,.jpeg,.png,.pdf,.ai,.psd" required>
                <small style="color: #999;">Accepted: JPG, PNG, PDF, AI, PSD</small>
              </div>

              <div class="form-group">
                <label for="instructions" class="form-label">Special Instructions</label>
                <textarea id="instructions" name="instructions" class="form-textarea" placeholder="Tell us about your design, color preferences, or any special requests..."></textarea>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="email" class="form-label">Email *</label>
                  <input type="email" id="email" name="email" class="form-input" required>
                </div>

                <div class="form-group">
                  <label for="phone" class="form-label">Phone *</label>
                  <input type="tel" id="phone" name="phone" class="form-input" required>
                </div>
              </div>

              {%- if section.settings.show_payment_notice -%}
                <div style="padding: 1rem; background-color: rgba(255, 20, 147, 0.1); border-radius: 8px; margin-top: 1rem;">
                  <p style="margin: 0; font-size: 0.95rem;">
                    <strong>Custom Design Fee: {{ section.settings.payment_amount }}</strong><br>
                    {%- if section.settings.payment_deadline != blank -%}
                      <small>Payment required by: {{ section.settings.payment_deadline }}</small>
                    {%- endif -%}
                  </p>
                </div>
              {%- endif -%}

              <button type="submit" class="form-submit-btn">Submit Design for Review</button>
            </form>

            <div id="success-message" class="success-message">
              <h3>✓ Thank You!</h3>
              <p>Your design submission has been received. We'll review it and send you a payment link via email shortly.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  const FORMSPREE_ENDPOINT = '{{ section.settings.formspree_endpoint }}';
  const boardHandleInput = document.getElementById('board-handle');
  const boardPreviewImage = document.getElementById('board-preview-image');
  const boardPreviewTitle = document.getElementById('board-preview-title');
  const boardNotFound = document.getElementById('board-not-found');
  const form = document.getElementById('board-customizer-form');
  const errorMessageDiv = document.getElementById('error-message');
  const successMessageDiv = document.getElementById('success-message');

  // Get board handle from URL parameter
  function getBoardHandle() {
    const params = new URLSearchParams(window.location.search);
    return params.get('board') || null;
  }

  // Load board preview
  async function loadBoardPreview(handle) {
    if (!handle) {
      boardNotFound.textContent = 'No board selected. Please go back and select a board.';
      boardNotFound.style.display = 'block';
      return;
    }

    try {
      const response = await fetch(`/products/${handle}.json`);
      if (!response.ok) throw new Error('Product not found');

      const data = await response.json();
      const product = data.product;

      boardHandleInput.value = handle;
      boardPreviewTitle.textContent = product.title;
      boardNotFound.style.display = 'none';

      if (product.featured_image) {
        boardPreviewImage.innerHTML = `<img src="${product.featured_image.src}" alt="${product.title}">`;
      }
    } catch (error) {
      console.error('Error loading board:', error);
      boardNotFound.textContent = 'Could not load board details. Please try again.';
      boardNotFound.style.display = 'block';
    }
  }

  // Handle form submission
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMessageDiv.classList.remove('show');
    successMessageDiv.classList.remove('show');

    if (!FORMSPREE_ENDPOINT) {
      errorMessageDiv.textContent = 'Form endpoint not configured. Please contact support.';
      errorMessageDiv.classList.add('show');
      return;
    }

    const formData = new FormData(form);

    try {
      const response = await fetch(FORMSPREE_ENDPOINT, {
        method: 'POST',
        body: formData,
        headers: {
          'Accept': 'application/json'
        }
      });

      if (response.ok) {
        form.style.display = 'none';
        successMessageDiv.classList.add('show');
        // Scroll to success message
        successMessageDiv.scrollIntoView({ behavior: 'smooth' });
      } else {
        const data = await response.json();
        errorMessageDiv.textContent = data.message || 'Error submitting form. Please try again.';
        errorMessageDiv.classList.add('show');
      }
    } catch (error) {
      console.error('Form submission error:', error);
      errorMessageDiv.textContent = 'Error submitting form. Please check your connection and try again.';
      errorMessageDiv.classList.add('show');
    }
  });

  // Load board on page load
  const handle = getBoardHandle();
  loadBoardPreview(handle);
})();
</script>

{% schema %}
{
  "name": "Board Customizer",
  "settings": [
    {
      "type": "text",
      "id": "formspree_endpoint",
      "label": "Formspree Endpoint URL",
      "placeholder": "https://formspree.io/f/YOUR_FORM_ID",
      "info": "Create a free Formspree account and paste your form endpoint here"
    },
    {
      "type": "checkbox",
      "id": "show_payment_notice",
      "label": "Show payment notice",
      "default": true
    },
    {
      "type": "text",
      "id": "payment_amount",
      "label": "Design fee amount",
      "placeholder": "$150 - $500 depending on complexity",
      "default": "$150 - $500"
    },
    {
      "type": "text",
      "id": "payment_deadline",
      "label": "Payment deadline",
      "placeholder": "e.g., April 15, 2026"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Board Customizer"
    }
  ]
}
{% endschema %}
