{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .customizer-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .customizer-layout {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  @media screen and (min-width: 750px) {
    .customizer-layout {
      grid-template-columns: 1fr 1fr;
    }
  }

  .board-preview {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .board-preview-image {
    border-radius: 12px;
    overflow: hidden;
    background-color: #f5f5f5;
    aspect-ratio: 1;
  }

  .board-preview-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .board-preview-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
    color: rgb(var(--color-foreground));
  }

  .customizer-form-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .email-info {
    padding: 1rem;
    background-color: rgba(255, 20, 147, 0.08);
    border-radius: 8px;
    border-left: 4px solid #FF1493;
    margin-bottom: 1rem;
  }

  .email-info p {
    margin: 0.5rem 0;
    color: rgb(var(--color-foreground));
    font-size: 0.95rem;
  }

  .email-info p:first-child {
    margin-top: 0;
  }

  .send-email-btn {
    display: inline-block;
    padding: 1rem 2rem;
    background-color: #FF1493;
    color: white;
    text-decoration: none;
    border: 2px solid #FF1493;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    width: 100%;
  }

  .send-email-btn:hover {
    background-color: #FF69B4;
    border-color: #FF69B4;
    box-shadow: 0 8px 32px rgba(255, 20, 147, 0.5);
    transform: translateY(-2px);
  }

  .payment-notice {
    padding: 1rem;
    background-color: rgba(255, 20, 147, 0.1);
    border-radius: 8px;
    margin-top: 1rem;
  }

  .payment-notice p {
    margin: 0;
    font-size: 0.95rem;
  }

  .payment-notice strong {
    color: #FF1493;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient">
  <div class="customizer-section section-{{ section.id }}-padding">
    <div class="page-width">
      <h1 style="text-align: center; margin-bottom: 2rem;">Design Your Board</h1>

      <div class="customizer-container">
        <div class="customizer-layout">
          <!-- Board Preview -->
          <div class="board-preview">
            <div class="board-preview-image" id="board-preview-image">
              <!-- Image will be loaded by JavaScript -->
            </div>
            <h2 class="board-preview-title" id="board-preview-title">Select a board</h2>
            <p id="board-not-found" style="text-align: center; color: #999;">Loading board details...</p>
          </div>

          <!-- Email Section -->
          <div class="customizer-form-section">
            <div class="email-info">
              <p><strong>Ready to submit your design?</strong></p>
              <p>Click the button below to open your email client with a pre-filled draft for this board. Just add your design attachment and any special requirements, then send!</p>
            </div>

            <a href="#" id="email-button" class="send-email-btn">Send Design Request via Email</a>

            {%- if section.settings.show_payment_notice -%}
              <div class="payment-notice">
                <p>
                  <strong>Custom Design Fee:</strong> {{ section.settings.payment_amount }}<br>
                  {%- if section.settings.payment_deadline != blank -%}
                    <strong>Payment deadline:</strong> {{ section.settings.payment_deadline }}
                  {%- endif -%}
                </p>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  const CONTACT_EMAIL = '{{ section.settings.contact_email }}';
  const boardPreviewImage = document.getElementById('board-preview-image');
  const boardPreviewTitle = document.getElementById('board-preview-title');
  const boardNotFound = document.getElementById('board-not-found');
  const emailButton = document.getElementById('email-button');

  // Get board handle from URL parameter
  function getBoardHandle() {
    const params = new URLSearchParams(window.location.search);
    return params.get('board') || null;
  }

  // Load board preview
  async function loadBoardPreview(handle) {
    if (!handle) {
      boardNotFound.textContent = 'No board selected. Please go back and select a board.';
      boardNotFound.style.display = 'block';
      emailButton.style.display = 'none';
      return;
    }

    try {
      const response = await fetch(`/products/${handle}.json`);
      if (!response.ok) throw new Error('Product not found');

      const data = await response.json();
      const product = data.product;

      const boardName = product.title;
      boardPreviewTitle.textContent = boardName;
      boardNotFound.style.display = 'none';

      if (product.featured_image) {
        boardPreviewImage.innerHTML = `<img src="${product.featured_image.src}" alt="${boardName}">`;
      }

      // Create mailto link with pre-filled email
      const subject = encodeURIComponent(`Custom Board Design Request: ${boardName}`);
      const body = encodeURIComponent(
        `Hi,\n\nI'd like to design a custom ${boardName} board.\n\n` +
        `Here are my design requirements and special instructions:\n` +
        `[Please describe your design ideas, colors, artwork, and any other details here]\n\n` +
        `Thanks!\n`
      );

      if (CONTACT_EMAIL) {
        emailButton.href = `mailto:${CONTACT_EMAIL}?subject=${subject}&body=${body}`;
      }
    } catch (error) {
      console.error('Error loading board:', error);
      boardNotFound.textContent = 'Could not load board details. Please try again.';
      boardNotFound.style.display = 'block';
      emailButton.style.display = 'none';
    }
  }

  // Load board on page load
  const handle = getBoardHandle();
  loadBoardPreview(handle);
})();
</script>

{% schema %}
{
  "name": "Board Customizer",
  "settings": [
    {
      "type": "email",
      "id": "contact_email",
      "label": "Contact email for design requests"
    },
    {
      "type": "checkbox",
      "id": "show_payment_notice",
      "label": "Show payment notice",
      "default": true
    },
    {
      "type": "text",
      "id": "payment_amount",
      "label": "Design fee amount",
      "placeholder": "$150 - $500 depending on complexity",
      "default": "$150 - $500"
    },
    {
      "type": "text",
      "id": "payment_deadline",
      "label": "Payment deadline",
      "placeholder": "e.g., April 15, 2026"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Board Customizer"
    }
  ]
}
{% endschema %}
