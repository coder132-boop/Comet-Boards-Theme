{% doc %}
  @prompt
    Create a stunning and eye-catching contact form section with modern design that includes name, email, subject, phone, message fields, and a file upload field. The form should be visually appealing with attractive styling and smooth user experience.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px;
    background: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
  }

  .ai-contact-form__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 40px;
  }

  .ai-contact-form__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-contact-form__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-contact-form__form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.field_spacing }}px;
  }

  .ai-contact-form__row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.field_spacing }}px;
  }

  .ai-contact-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-contact-form__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    font-weight: 500;
  }

  .ai-contact-form__input-{{ ai_gen_id }},
  .ai-contact-form__textarea-{{ ai_gen_id }},
  .ai-contact-form__file-input-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.input_padding }}px;
    font-size: {{ block.settings.input_text_size }}px;
    color: {{ block.settings.input_text_color }};
    background-color: {{ block.settings.input_background }};
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    transition: all 0.3s ease;
    font-family: inherit;
  }

  .ai-contact-form__input-{{ ai_gen_id }}:focus,
  .ai-contact-form__textarea-{{ ai_gen_id }}:focus,
  .ai-contact-form__file-input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: #FF1493;
    box-shadow: 0 0 0 3px rgba(255, 20, 147, 0.2);
  }

  .ai-contact-form__input-{{ ai_gen_id }}::placeholder,
  .ai-contact-form__textarea-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.placeholder_color }};
    opacity: 0.7;
  }

  .ai-contact-form__textarea-{{ ai_gen_id }} {
    min-height: {{ block.settings.textarea_height }}px;
    resize: vertical;
  }

  .ai-contact-form__file-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-contact-form__file-input-{{ ai_gen_id }} {
    cursor: pointer;
  }

  .ai-contact-form__file-input-{{ ai_gen_id }}::file-selector-button {
    padding: 10px 20px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-weight: 500;
    margin-right: 12px;
    transition: background-color 0.3s ease;
  }

  .ai-contact-form__file-input-{{ ai_gen_id }}::file-selector-button:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-contact-form__button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    color: #ffffff;
    background-color: #FF1493;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    width: 100%;
    margin-top: {{ block.settings.field_spacing }}px;
  }

  .ai-contact-form__button-{{ ai_gen_id }}:hover {
    background-color: #FF1493;
    transform: translateY(-2px);
    box-shadow: 0 0 20px rgba(255, 20, 147, 0.6);
  }

  .ai-contact-form__success-{{ ai_gen_id }} {
    padding: 20px;
    background-color: {{ block.settings.success_bg }};
    color: {{ block.settings.success_text }};
    border-radius: {{ block.settings.input_border_radius }}px;
    text-align: center;
    font-size: {{ block.settings.input_text_size }}px;
    margin-bottom: 20px;
  }

  .ai-contact-form__error-{{ ai_gen_id }} {
    padding: 20px;
    background-color: {{ block.settings.error_bg }};
    color: {{ block.settings.error_text }};
    border-radius: {{ block.settings.input_border_radius }}px;
    text-align: center;
    font-size: {{ block.settings.input_text_size }}px;
    margin-bottom: 20px;
  }

  .ai-contact-form__required-{{ ai_gen_id }} {
    color: {{ block.settings.error_text }};
  }

  /* Trust signals */
  .ai-contact-trust-{{ ai_gen_id }} {
    margin-bottom: 36px;
  }

  .ai-contact-trust-callout-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.heading_color }};
    font-weight: 600;
    background: {{ block.settings.trust_callout_bg }};
    border-left: 3px solid {{ block.settings.trust_accent_color }};
    padding: 12px 16px;
    border-radius: 0 4px 4px 0;
    margin-bottom: 28px;
    line-height: 1.5;
  }

  .ai-contact-testimonials-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 8px;
  }

  .ai-contact-testimonial-{{ ai_gen_id }} {
    background: {{ block.settings.testimonial_bg }};
    border: 1px solid {{ block.settings.testimonial_border }};
    border-radius: 8px;
    padding: 16px;
  }

  .ai-contact-testimonial-quote-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    line-height: 1.55;
    margin: 0 0 10px;
    font-style: italic;
  }

  .ai-contact-testimonial-name-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.heading_color }};
    font-weight: 600;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-testimonials-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-contact-form-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.section_padding | times: 0.6 }}px;
    }

    .ai-contact-form__row-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-contact-form__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-contact-form__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<contact-form-{{ ai_gen_id }} class="ai-contact-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-form__header-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-contact-form__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}
    {% if block.settings.description != blank %}
      <div class="ai-contact-form__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}
  </div>

  {% if block.settings.show_trust_signals %}
    <div class="ai-contact-trust-{{ ai_gen_id }}">
      {% if block.settings.trust_callout != blank %}
        <p class="ai-contact-trust-callout-{{ ai_gen_id }}">{{ block.settings.trust_callout }}</p>
      {% endif %}
      {% assign has_t1 = false %}
      {% assign has_t2 = false %}
      {% assign has_t3 = false %}
      {% if block.settings.testimonial_1_quote != blank %}{% assign has_t1 = true %}{% endif %}
      {% if block.settings.testimonial_2_quote != blank %}{% assign has_t2 = true %}{% endif %}
      {% if block.settings.testimonial_3_quote != blank %}{% assign has_t3 = true %}{% endif %}
      {% if has_t1 or has_t2 or has_t3 %}
        <div class="ai-contact-testimonials-{{ ai_gen_id }}">
          {% if has_t1 %}
            <div class="ai-contact-testimonial-{{ ai_gen_id }}">
              <p class="ai-contact-testimonial-quote-{{ ai_gen_id }}">"{{ block.settings.testimonial_1_quote }}"</p>
              {% if block.settings.testimonial_1_name != blank %}
                <p class="ai-contact-testimonial-name-{{ ai_gen_id }}">{{ block.settings.testimonial_1_name }}</p>
              {% endif %}
            </div>
          {% endif %}
          {% if has_t2 %}
            <div class="ai-contact-testimonial-{{ ai_gen_id }}">
              <p class="ai-contact-testimonial-quote-{{ ai_gen_id }}">"{{ block.settings.testimonial_2_quote }}"</p>
              {% if block.settings.testimonial_2_name != blank %}
                <p class="ai-contact-testimonial-name-{{ ai_gen_id }}">{{ block.settings.testimonial_2_name }}</p>
              {% endif %}
            </div>
          {% endif %}
          {% if has_t3 %}
            <div class="ai-contact-testimonial-{{ ai_gen_id }}">
              <p class="ai-contact-testimonial-quote-{{ ai_gen_id }}">"{{ block.settings.testimonial_3_quote }}"</p>
              {% if block.settings.testimonial_3_name != blank %}
                <p class="ai-contact-testimonial-name-{{ ai_gen_id }}">{{ block.settings.testimonial_3_name }}</p>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  {% endif %}

  {%- form 'contact' -%}
    {% if form.posted_successfully? %}
      <div class="ai-contact-form__success-{{ ai_gen_id }}" id="ai-contact-form-success-{{ ai_gen_id }}">
        {{ block.settings.success_message }}
      </div>
    {% endif %}

    {% if form.errors %}
      <div class="ai-contact-form__error-{{ ai_gen_id }}" id="ai-contact-form-error-{{ ai_gen_id }}">
        {{ form.errors | default_errors }}
      </div>
    {% endif %}

    <div class="ai-contact-form__form-{{ ai_gen_id }}">
      <div class="ai-contact-form__row-{{ ai_gen_id }}">
        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="ai-contact-name-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.name_label }}
            {% if block.settings.name_required %}
              <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
            {% endif %}
          </label>
          <input
            type="text"
            id="ai-contact-name-{{ ai_gen_id }}"
            name="contact[{{ block.settings.name_label }}]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            placeholder="{{ block.settings.name_placeholder }}"
            {% if block.settings.name_required %}required{% endif %}
            autocomplete="name"
          >
        </div>

        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="ai-contact-email-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.email_label }}
            <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="email"
            id="ai-contact-email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            placeholder="{{ block.settings.email_placeholder }}"
            required
            autocomplete="email"
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
            {% endif %}
          >
        </div>
      </div>

      <div class="ai-contact-form__row-{{ ai_gen_id }}">
        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="ai-contact-phone-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.phone_label }}
            {% if block.settings.phone_required %}
              <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
            {% endif %}
          </label>
          <input
            type="tel"
            id="ai-contact-phone-{{ ai_gen_id }}"
            name="contact[{{ block.settings.phone_label }}]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            placeholder="{{ block.settings.phone_placeholder }}"
            {% if block.settings.phone_required %}required{% endif %}
            autocomplete="tel"
          >
        </div>

        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="ai-contact-subject-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.subject_label }}
            {% if block.settings.subject_required %}
              <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
            {% endif %}
          </label>
          <input
            type="text"
            id="ai-contact-subject-{{ ai_gen_id }}"
            name="contact[{{ block.settings.subject_label }}]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            placeholder="{{ block.settings.subject_placeholder }}"
            {% if block.settings.subject_required %}required{% endif %}
          >
        </div>
      </div>

      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label for="ai-contact-message-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
          {{ block.settings.message_label }}
          {% if block.settings.message_required %}
            <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
          {% endif %}
        </label>
        <textarea
          id="ai-contact-message-{{ ai_gen_id }}"
          name="contact[body]"
          class="ai-contact-form__textarea-{{ ai_gen_id }}"
          placeholder="{{ block.settings.message_placeholder }}"
          {% if block.settings.message_required %}required{% endif %}
        ></textarea>
      </div>

      {% if block.settings.show_file_upload %}
        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="ai-contact-file-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.file_label }}
            {% if block.settings.file_required %}
              <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
            {% endif %}
          </label>
          <div class="ai-contact-form__file-wrapper-{{ ai_gen_id }}">
            <input
              type="file"
              id="ai-contact-file-{{ ai_gen_id }}"
              name="contact[file]"
              class="ai-contact-form__file-input-{{ ai_gen_id }}"
              accept="{{ block.settings.file_accept }}"
              {% if block.settings.file_required %}required{% endif %}
            >
          </div>
        </div>
      {% endif %}

      <button type="submit" class="ai-contact-form__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>
    </div>
  {%- endform -%}
</contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        const successMessage = this.querySelector('#ai-contact-form-success-{{ ai_gen_id }}');
        
        if (successMessage) {
          successMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        if (form) {
          form.addEventListener('submit', function(e) {
            const requiredFields = form.querySelectorAll('[required]');
            let isValid = true;

            requiredFields.forEach(function(field) {
              if (!field.value.trim()) {
                isValid = false;
                field.style.borderColor = '{{ block.settings.error_text }}';
              } else {
                field.style.borderColor = '{{ block.settings.input_border_color }}';
              }
            });

            if (!isValid) {
              e.preventDefault();
            }
          });

          const inputs = form.querySelectorAll('input, textarea');
          inputs.forEach(function(input) {
            input.addEventListener('input', function() {
              if (this.hasAttribute('required') && this.value.trim()) {
                this.style.borderColor = '{{ block.settings.input_border_color }}';
              }
            });
          });
        }
      }
    }

    customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
  })();
</script>

