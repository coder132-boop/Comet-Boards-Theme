{% doc %}
  @prompt
    Create a custom multicolumn section with yellow card backgrounds that has separate, independent color controls for:
    1. The main heading text (should be yellow)
    2. The text inside each card/column (should be black)
    
    The section should display multiple columns with cards, similar to a standard multicolumn section, but with individual color settings for heading text and card text that can be configured separately without using color schemes.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-multicolumn-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-multicolumn-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-multicolumn-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_text_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
  }

  .ai-multicolumn-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-multicolumn-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    padding: {{ block.settings.card_padding }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    text-align: {{ block.settings.card_text_alignment }};
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-multicolumn-card-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-multicolumn-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-multicolumn-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #242428;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-multicolumn-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-multicolumn-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    margin: 0;
    color: {{ block.settings.card_text_color }};
  }

  .ai-multicolumn-card-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    line-height: 1.6;
    margin: 0;
    color: {{ block.settings.card_text_color }};
  }

  .ai-multicolumn-card-link-{{ ai_gen_id }} {
    display: inline-block;
    margin-top: 8px;
    padding: 10px 22px;
    background-color: {{ block.settings.card_text_color }};
    color: {{ block.settings.card_background_color }};
    text-decoration: none;
    font-size: {{ block.settings.card_text_size }}px;
    font-weight: 600;
    border-radius: 4px;
    letter-spacing: 0.03em;
    transition: opacity 150ms ease, transform 150ms ease;
    cursor: pointer;
  }

  .ai-multicolumn-card-link-{{ ai_gen_id }}:hover {
    opacity: 0.85;
    transform: translateY(-2px);
    text-decoration: none;
  }

  @media screen and (max-width: 989px) {
    .ai-multicolumn-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-multicolumn-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-multicolumn-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<div class="ai-multicolumn-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-multicolumn-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-multicolumn-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-multicolumn-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign image_key = 'column_' | append: i | append: '_image'
          assign title_key = 'column_' | append: i | append: '_title'
          assign text_key = 'column_' | append: i | append: '_text'
          assign link_key = 'column_' | append: i | append: '_link'
          assign link_text_key = 'column_' | append: i | append: '_link_text'

          assign column_image = block.settings[image_key]
          assign column_title = block.settings[title_key]
          assign column_text = block.settings[text_key]
          assign column_link = block.settings[link_key]
          assign column_link_text = block.settings[link_text_key]
        %}

        {% if column_title != blank or column_text != blank or column_image != blank %}
          <div class="ai-multicolumn-card-{{ ai_gen_id }}">
            {% if column_image != blank %}
              <div class="ai-multicolumn-card-image-wrapper-{{ ai_gen_id }}">
                <img
                  src="{{ column_image | image_url: width: 600 }}"
                  alt="{{ column_image.alt | escape }}"
                  class="ai-multicolumn-card-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ column_image.width }}"
                  height="{{ column_image.height }}"
                >
              </div>
            {% else %}
              <div class="ai-multicolumn-card-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}

            {% if column_title != blank %}
              <h3 class="ai-multicolumn-card-title-{{ ai_gen_id }}">{{ column_title }}</h3>
            {% endif %}

            {% if column_text != blank %}
              <div class="ai-multicolumn-card-text-{{ ai_gen_id }}">{{ column_text }}</div>
            {% endif %}

            {% if column_link != blank and column_link_text != blank %}
              <a href="{{ column_link }}" class="ai-multicolumn-card-link-{{ ai_gen_id }}">
                {{ column_link_text }}
              </a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

