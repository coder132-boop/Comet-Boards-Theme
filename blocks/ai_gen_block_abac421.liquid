{% doc %}
  @prompt
    Create a stunning and eye-catching contact form section with modern design, attractive styling, and smooth user experience. The form should be visually appealing and stand out on the page. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px;
    background: {{ block.settings.background_gradient }};
    border-radius: {{ block.settings.container_radius }}px;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
  }

  .ai-contact-form__inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.form_max_width }}px;
    margin: 0 auto;
  }

  .ai-contact-form__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 40px;
  }

  .ai-contact-form__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-contact-form__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    opacity: 0.9;
  }

  .ai-contact-form__form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-contact-form__field-group-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .ai-contact-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-contact-form__label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.label_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-contact-form__input-{{ ai_gen_id }},
  .ai-contact-form__textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 20px;
    font-size: 16px;
    color: {{ block.settings.input_text_color }};
    background-color: {{ block.settings.input_bg_color }};
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_radius }}px;
    transition: all 0.3s ease;
    font-family: inherit;
  }

  .ai-contact-form__input-{{ ai_gen_id }}:focus,
  .ai-contact-form__textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border_color }};
    box-shadow: 0 0 0 3px {{ block.settings.input_focus_border_color }}33;
    transform: translateY(-2px);
  }

  .ai-contact-form__input-{{ ai_gen_id }}::placeholder,
  .ai-contact-form__textarea-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.placeholder_color }};
    opacity: 0.6;
  }

  .ai-contact-form__textarea-{{ ai_gen_id }} {
    min-height: 150px;
    resize: vertical;
  }

  .ai-contact-form__button-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.button_alignment }};
    margin-top: 16px;
  }

  .ai-contact-form__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 18px 48px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 700;
    color: {{ block.settings.button_text_color }};
    background: {{ block.settings.button_bg_gradient }};
    border: none;
    border-radius: {{ block.settings.button_radius }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 1px;
    box-shadow: 0 4px 15px {{ block.settings.button_bg_color }}40;
  }

  .ai-contact-form__button-{{ ai_gen_id }}:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px {{ block.settings.button_bg_color }}60;
  }

  .ai-contact-form__button-{{ ai_gen_id }}:active {
    transform: translateY(-1px);
  }

  .ai-contact-form__message-{{ ai_gen_id }} {
    padding: 16px 20px;
    border-radius: {{ block.settings.input_radius }}px;
    margin-top: 20px;
    font-size: 15px;
    font-weight: 500;
  }

  .ai-contact-form__success-{{ ai_gen_id }} {
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
    border: 2px solid {{ block.settings.success_text_color }};
  }

  .ai-contact-form__error-{{ ai_gen_id }} {
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
    border: 2px solid {{ block.settings.error_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-contact-form__field-group-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .ai-contact-form__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-contact-form__subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.85);
    }

    .ai-contact-form__button-{{ ai_gen_id }} {
      width: 100%;
      padding: 16px 32px;
    }
  }
{% endstyle %}

<contact-form-{{ ai_gen_id }} class="ai-contact-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-form__inner-{{ ai_gen_id }}">
    <div class="ai-contact-form__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-contact-form__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-contact-form__subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>

    {%- form 'contact' -%}
      <div class="ai-contact-form__form-{{ ai_gen_id }}">
        <div class="ai-contact-form__field-group-{{ ai_gen_id }}">
          <div class="ai-contact-form__field-{{ ai_gen_id }}">
            <label for="contact-name-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
              {{ block.settings.name_label }}
            </label>
            <input
              type="text"
              id="contact-name-{{ ai_gen_id }}"
              name="contact[name]"
              class="ai-contact-form__input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.name_placeholder }}"
              autocomplete="name"
              required
            >
          </div>

          <div class="ai-contact-form__field-{{ ai_gen_id }}">
            <label for="contact-email-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
              {{ block.settings.email_label }}
            </label>
            <input
              type="email"
              id="contact-email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-contact-form__input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.email_placeholder }}"
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="contact-error-{{ ai_gen_id }}"
              {% endif %}
              {% if form.posted_successfully? %}
                aria-describedby="contact-success-{{ ai_gen_id }}"
              {% endif %}
              required
            >
          </div>
        </div>

        {% if block.settings.show_phone %}
          <div class="ai-contact-form__field-{{ ai_gen_id }}">
            <label for="contact-phone-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
              {{ block.settings.phone_label }}
            </label>
            <input
              type="tel"
              id="contact-phone-{{ ai_gen_id }}"
              name="contact[phone]"
              class="ai-contact-form__input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.phone_placeholder }}"
              autocomplete="tel"
            >
          </div>
        {% endif %}

        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="contact-message-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.message_label }}
          </label>
          <textarea
            id="contact-message-{{ ai_gen_id }}"
            name="contact[body]"
            class="ai-contact-form__textarea-{{ ai_gen_id }}"
            placeholder="{{ block.settings.message_placeholder }}"
            required
          ></textarea>
        </div>

        <div class="ai-contact-form__button-wrapper-{{ ai_gen_id }}">
          <button type="submit" class="ai-contact-form__button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
          </button>
        </div>

        {%- if form.posted_successfully? -%}
          <div id="contact-success-{{ ai_gen_id }}" class="ai-contact-form__message-{{ ai_gen_id }} ai-contact-form__success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div id="contact-error-{{ ai_gen_id }}" class="ai-contact-form__message-{{ ai_gen_id }} ai-contact-form__error-{{ ai_gen_id }}">
            {{ form.errors.messages.email }}
          </div>
        {%- endif -%}
      </div>
    {%- endform -%}
  </div>
</contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.form = this.querySelector('form');
        this.inputs = this.querySelectorAll('.ai-contact-form__input-{{ ai_gen_id }}, .ai-contact-form__textarea-{{ ai_gen_id }}');
        this.setupInputEffects();
      }

      setupInputEffects() {
        this.inputs.forEach(input => {
          input.addEventListener('focus', () => {
            input.parentElement.style.transform = 'scale(1.01)';
          });

          input.addEventListener('blur', () => {
            input.parentElement.style.transform = 'scale(1)';
          });
        });
      }
    }

    customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
  })();
</script>

