{% doc %}
  @prompt
    Create an app/form section with background image support that includes an overlay opacity control to dim the background image. The section should display a form with the background image behind it, and allow merchants to adjust how dimmed the background appears so the form remains prominent and readable.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-form-with-bg-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    min-height: {{ block.settings.min_height }}px;
    overflow: hidden;
  }

  .ai-form-with-bg__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-form-with-bg__background-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-form-with-bg__background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-form-with-bg__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-form-with-bg__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .ai-form-with-bg__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: {{ block.settings.min_height }}px;
    padding: 40px 20px;
  }

  .ai-form-with-bg__form-container-{{ ai_gen_id }} {
    background-color: {{ block.settings.form_background_color }};
    border-radius: {{ block.settings.form_border_radius }}px;
    padding: {{ block.settings.form_padding }}px;
    max-width: {{ block.settings.form_max_width }}px;
    width: 100%;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .ai-form-with-bg__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 8px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-form-with-bg__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 24px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-form-with-bg__field-{{ ai_gen_id }} {
    margin-bottom: 16px;
  }

  .ai-form-with-bg__label-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    margin-bottom: 6px;
    font-weight: 500;
  }

  .ai-form-with-bg__input-{{ ai_gen_id }},
  .ai-form-with-bg__textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-form-with-bg__textarea-{{ ai_gen_id }} {
    min-height: 100px;
    resize: vertical;
  }

  .ai-form-with-bg__input-{{ ai_gen_id }}:focus,
  .ai-form-with-bg__textarea-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.button_color }};
    outline-offset: 2px;
  }

  .ai-form-with-bg__button-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-form-with-bg__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-form-with-bg__success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    margin-top: 12px;
    text-align: center;
    font-size: 14px;
  }

  .ai-form-with-bg__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    margin-top: 12px;
    text-align: center;
    font-size: 14px;
  }

  .ai-form-with-bg__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    z-index: 4;
  }

  @media screen and (max-width: 749px) {
    .ai-form-with-bg__content-{{ ai_gen_id }} {
      padding: 30px 15px;
    }

    .ai-form-with-bg__form-container-{{ ai_gen_id }} {
      padding: {{ block.settings.form_padding | times: 0.7 }}px;
    }

    .ai-form-with-bg__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<form-with-background-{{ ai_gen_id }}
  class="ai-form-with-bg-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-form-with-bg__background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-form-with-bg__background-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-form-with-bg__background-placeholder-{{ ai_gen_id }}">
        {{ 'lifestyle-1' | placeholder_svg_tag }}
      </div>
      <div class="ai-form-with-bg__empty-state-{{ ai_gen_id }}">
        Next, add a background image
      </div>
    {% endif %}
  </div>

  <div class="ai-form-with-bg__overlay-{{ ai_gen_id }}"></div>

  <div class="ai-form-with-bg__content-{{ ai_gen_id }}">
    <div class="ai-form-with-bg__form-container-{{ ai_gen_id }}">
      {%- if block.settings.heading != blank -%}
        <h2 class="ai-form-with-bg__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {%- endif -%}

      {%- if block.settings.subheading != blank -%}
        <div class="ai-form-with-bg__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
      {%- endif -%}

      {%- form 'contact' -%}
        <input
          type="hidden"
          name="contact[form_type]"
          value="{{ block.settings.form_type }}"
        >

        <div class="ai-form-with-bg__field-{{ ai_gen_id }}">
          <label
            for="ai-form-name-{{ ai_gen_id }}"
            class="ai-form-with-bg__label-{{ ai_gen_id }}"
          >
            Name
          </label>
          <input
            type="text"
            id="ai-form-name-{{ ai_gen_id }}"
            name="contact[name]"
            class="ai-form-with-bg__input-{{ ai_gen_id }}"
            value="{{ form.name }}"
            required
          >
        </div>

        <div class="ai-form-with-bg__field-{{ ai_gen_id }}">
          <label
            for="ai-form-email-{{ ai_gen_id }}"
            class="ai-form-with-bg__label-{{ ai_gen_id }}"
          >
            Email
          </label>
          <input
            type="email"
            id="ai-form-email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-form-with-bg__input-{{ ai_gen_id }}"
            value="{{ form.email }}"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="ai-form-error-{{ ai_gen_id }}"
            {% endif %}
            {% if form.posted_successfully? %}
              aria-describedby="ai-form-success-{{ ai_gen_id }}"
            {% endif %}
            required
          >
        </div>

        {% if block.settings.show_phone %}
          <div class="ai-form-with-bg__field-{{ ai_gen_id }}">
            <label
              for="ai-form-phone-{{ ai_gen_id }}"
              class="ai-form-with-bg__label-{{ ai_gen_id }}"
            >
              Phone
            </label>
            <input
              type="tel"
              id="ai-form-phone-{{ ai_gen_id }}"
              name="contact[phone]"
              class="ai-form-with-bg__input-{{ ai_gen_id }}"
              value="{{ form.phone }}"
              autocomplete="tel"
            >
          </div>
        {% endif %}

        <div class="ai-form-with-bg__field-{{ ai_gen_id }}">
          <label
            for="ai-form-message-{{ ai_gen_id }}"
            class="ai-form-with-bg__label-{{ ai_gen_id }}"
          >
            Message
          </label>
          <textarea
            id="ai-form-message-{{ ai_gen_id }}"
            name="contact[body]"
            class="ai-form-with-bg__textarea-{{ ai_gen_id }}"
            required
          >{{ form.body }}</textarea>
        </div>

        <button
          type="submit"
          class="ai-form-with-bg__button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </button>

        {%- if form.errors -%}
          <div
            id="ai-form-error-{{ ai_gen_id }}"
            class="ai-form-with-bg__error-{{ ai_gen_id }}"
          >
            <span>{{ form.errors.messages.email }}</span>
          </div>
        {%- endif -%}

        {%- if form.posted_successfully? -%}
          <div
            id="ai-form-success-{{ ai_gen_id }}"
            class="ai-form-with-bg__success-{{ ai_gen_id }}"
          >
            <span>{{ block.settings.success_message }}</span>
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</form-with-background-{{ ai_gen_id }}>

<script>
  (function() {
    class FormWithBackground{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.form = this.querySelector('form');
        if (this.form) {
          this.form.addEventListener('submit', this.handleSubmit.bind(this));
        }
      }

      handleSubmit(event) {
        const requiredFields = this.form.querySelectorAll('[required]');
        let isValid = true;

        requiredFields.forEach(field => {
          if (!field.value.trim()) {
            isValid = false;
            field.setAttribute('aria-invalid', 'true');
          } else {
            field.removeAttribute('aria-invalid');
          }
        });

        if (!isValid) {
          event.preventDefault();
        }
      }
    }

    customElements.define('form-with-background-{{ ai_gen_id }}', FormWithBackground{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Form with background",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Minimum height",
      "default": 500
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 50
    },
    {
      "type": "header",
      "content": "Form content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Get in touch"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "We'd love to hear from you"
    },
    {
      "type": "text",
      "id": "form_type",
      "label": "Form type identifier",
      "default": "contact"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show phone field",
      "default": false
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Send message"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks for contacting us. We'll get back to you soon."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Form style"
    },
    {
      "type": "range",
      "id": "form_max_width",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Form maximum width",
      "default": 500
    },
    {
      "type": "range",
      "id": "form_padding",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Form padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "form_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Form border radius",
      "default": 8
    },
    {
      "type": "color",
      "id": "form_background_color",
      "label": "Form background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1f1f21"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1f1f21"
    },
    {
      "type": "header",
      "content": "Input fields"
    },
    {
      "type": "color",
      "id": "input_background_color",
      "label": "Input background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Input border color",
      "default": "#cccccc"
    },
    {
      "type": "range",
      "id": "input_border_radius",
      "min": 0,
      "max": 20,
