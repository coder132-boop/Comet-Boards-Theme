{% doc %}
  @prompt
    Create a contact form section with background image support and file upload capability. The form should include fields for name, email, message, and a file upload field for customers to submit design files. Include an overlay opacity control to dim the background image so the form remains readable. The form should have transparent background and yellow text styling to match the theme.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-container-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    min-height: {{ block.settings.min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
  }

  .ai-contact-form-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-contact-form-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-contact-form-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1f1f21;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-contact-form-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
    opacity: 0.3;
  }

  .ai-contact-form-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .ai-contact-form-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: {{ block.settings.form_max_width }}px;
    background-color: {{ block.settings.form_background_color }};
    padding: {{ block.settings.form_padding }}px;
    border-radius: {{ block.settings.form_border_radius }}px;
  }

  .ai-contact-form-heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form-subheading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 {{ block.settings.form_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
    opacity: 0.9;
  }

  .ai-contact-form-fields-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.field_spacing }}px;
  }

  .ai-contact-form-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-contact-form-label-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.label_size }}px;
    font-weight: 500;
  }

  .ai-contact-form-input-{{ ai_gen_id }},
  .ai-contact-form-textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
    border: {{ block.settings.input_border_thickness }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 16px;
    font-family: inherit;
  }

  .ai-contact-form-input-{{ ai_gen_id }}::placeholder,
  .ai-contact-form-textarea-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_text_color }};
    opacity: 0.6;
  }

  .ai-contact-form-input-{{ ai_gen_id }}:focus,
  .ai-contact-form-textarea-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.text_color }};
    outline-offset: 2px;
  }

  .ai-contact-form-textarea-{{ ai_gen_id }} {
    min-height: {{ block.settings.message_height }}px;
    resize: vertical;
  }

  .ai-contact-form-file-input-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-contact-form-file-input-{{ ai_gen_id }} {
    position: absolute;
    opacity: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }

  .ai-contact-form-file-label-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 16px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
    border: {{ block.settings.input_border_thickness }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .ai-contact-form-file-label-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-contact-form-file-name-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 14px;
    margin-top: 8px;
    opacity: 0.8;
  }

  .ai-contact-form-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 32px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
    margin-top: {{ block.settings.button_spacing }}px;
  }

  .ai-contact-form-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-contact-form-success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    background-color: {{ block.settings.success_background }};
    padding: 12px 16px;
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-top: {{ block.settings.field_spacing }}px;
    text-align: center;
  }

  .ai-contact-form-error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    background-color: {{ block.settings.error_background }};
    padding: 12px 16px;
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-top: {{ block.settings.field_spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-form-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.6 }}px {{ block.settings.padding_horizontal | times: 0.6 }}px;
    }

    .ai-contact-form-content-{{ ai_gen_id }} {
      padding: {{ block.settings.form_padding | times: 0.7 }}px;
    }

    .ai-contact-form-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-contact-form-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<contact-form-{{ ai_gen_id }}
  class="ai-contact-form-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-contact-form-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-contact-form-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-contact-form-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-contact-form-content-{{ ai_gen_id }}">
    {%- form 'contact' -%}
      {% if block.settings.heading != blank %}
        <h2 class="ai-contact-form-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <div class="ai-contact-form-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
      {% endif %}

      <div class="ai-contact-form-fields-{{ ai_gen_id }}">
        <div class="ai-contact-form-field-{{ ai_gen_id }}">
          <label for="contact-name-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">
            {{ block.settings.name_label }}
          </label>
          <input
            type="text"
            id="contact-name-{{ ai_gen_id }}"
            name="contact[name]"
            class="ai-contact-form-input-{{ ai_gen_id }}"
            placeholder="{{ block.settings.name_placeholder }}"
            required
          >
        </div>

        <div class="ai-contact-form-field-{{ ai_gen_id }}">
          <label for="contact-email-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">
            {{ block.settings.email_label }}
          </label>
          <input
            type="email"
            id="contact-email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-contact-form-input-{{ ai_gen_id }}"
            placeholder="{{ block.settings.email_placeholder }}"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="contact-form-error-{{ ai_gen_id }}"
            {% endif %}
            required
          >
        </div>

        <div class="ai-contact-form-field-{{ ai_gen_id }}">
          <label for="contact-message-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">
            {{ block.settings.message_label }}
          </label>
          <textarea
            id="contact-message-{{ ai_gen_id }}"
            name="contact[body]"
            class="ai-contact-form-textarea-{{ ai_gen_id }}"
            placeholder="{{ block.settings.message_placeholder }}"
            required
          ></textarea>
        </div>

        {% if block.settings.enable_file_upload %}
          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label class="ai-contact-form-label-{{ ai_gen_id }}">
              {{ block.settings.file_label }}
            </label>
            <div class="ai-contact-form-file-input-wrapper-{{ ai_gen_id }}">
              <input
                type="file"
                id="contact-file-{{ ai_gen_id }}"
                class="ai-contact-form-file-input-{{ ai_gen_id }}"
                accept="{{ block.settings.accepted_file_types }}"
                data-file-input
              >
              <div class="ai-contact-form-file-label-{{ ai_gen_id }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="17 8 12 3 7 8"></polyline>
                  <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                <span>{{ block.settings.file_button_text }}</span>
              </div>
            </div>
            <div class="ai-contact-form-file-name-{{ ai_gen_id }}" data-file-name></div>
          </div>
        {% endif %}

        <button type="submit" class="ai-contact-form-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </button>
      </div>

      {%- if form.posted_successfully? -%}
        <div
          id="contact-form-success-{{ ai_gen_id }}"
          class="ai-contact-form-success-{{ ai_gen_id }}"
        >
          {{ block.settings.success_message }}
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div
          id="contact-form-error-{{ ai_gen_id }}"
          class="ai-contact-form-error-{{ ai_gen_id }}"
        >
          {{ form.errors.messages | join: ', ' }}
        </div>
      {%- endif -%}
    {%- endform -%}
  </div>
</contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.fileInput = this.querySelector('[data-file-input]');
        this.fileNameDisplay = this.querySelector('[data-file-name]');

        if (this.fileInput && this.fileNameDisplay) {
          this.fileInput.addEventListener('change', this.handleFileChange.bind(this));
        }
      }

      handleFileChange(event) {
        const file = event.target.files[0];
        if (file) {
          this.fileNameDisplay.textContent = `Selected: ${file.name}`;
        } else {
          this.fileNameDisplay.textContent = '';
        }
      }
    }

    customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
  })();
</script>

